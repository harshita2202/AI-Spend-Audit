# SpendSense AI — environment variables
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control.

# Supabase — required for persisting audits and leads
# Get these from your Supabase project settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Anthropic (Claude) — optional
# Used to generate the AI summary on the results page.
# If not set, a static template summary is used instead.
# NOTE: Direct browser → Anthropic API calls are supported via
# the anthropic-dangerous-direct-browser-access header.
VITE_ANTHROPIC_API_KEY=sk-ant-...

# Resend — optional
# Used to send the confirmation/savings-summary email.
# NOTE: Direct browser → Resend calls are blocked by CORS.
# Move sendConfirmationEmail() to a server-side proxy endpoint
# before using this in production (see src/lib/email.ts for the TODO).
VITE_RESEND_API_KEY=re_...
